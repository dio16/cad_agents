{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cad-agents.local/schemas/phase1/requirement.schema.json",
  "title": "Phase 1 Requirement JSON",
  "type": "object",
  "required": ["traceability_id", "product_type", "functional_requirements", "dimensions", "manufacturing", "unknowns", "assumptions"],
  "properties": {
    "traceability_id": {
      "type": "string",
      "pattern": "^tr_req_[A-Za-z0-9_]+$"
    },
    "product_type": {
      "type": "string",
      "minLength": 1
    },
    "functional_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "dimensions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "number"
      }
    },
    "manufacturing": {
      "type": "object",
      "required": ["primary_process"],
      "properties": {
        "primary_process": {
          "type": "string",
          "minLength": 1
        },
        "printer_class": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
