{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cad-agents.local/schemas/phase1/validation_report.schema.json",
  "title": "Phase 1 Validation Report",
  "type": "object",
  "required": ["traceability_id", "specification_id", "artifact_ids", "dimensions_check", "topology_check", "unit_consistency", "manufacturing_profile_rules", "artifact_provenance_check", "pass", "failures", "revision_feedback"],
  "properties": {
    "traceability_id": {
      "type": "string",
      "pattern": "^tr_val_[A-Za-z0-9_]+$"
    },
    "specification_id": {
      "type": "string",
      "pattern": "^tr_spec_[A-Za-z0-9_]+$"
    },
    "artifact_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "dimensions_check": {
      "$ref": "#/$defs/validation_check"
    },
    "topology_check": {
      "$ref": "#/$defs/validation_check"
    },
    "unit_consistency": {
      "$ref": "#/$defs/validation_check"
    },
    "manufacturing_profile_rules": {
      "$ref": "#/$defs/validation_check"
    },
    "artifact_provenance_check": {
      "$ref": "#/$defs/validation_check"
    },
    "pass": {
      "type": "boolean"
    },
    "failures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failure_item"
      }
    },
    "revision_feedback": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/revision_feedback_item"
      }
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "validation_check": {
      "type": "object",
      "required": ["status", "reason_code", "detail"],
      "properties": {
        "status": {
          "enum": ["pass", "fail"]
        },
        "reason_code": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        },
        "bbox_mm": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "volume_mm3": {
          "type": "number"
        },
        "watertight": {
          "type": "boolean"
        },
        "self_intersection": {
          "type": "boolean"
        },
        "units": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        },
        "min_wall_mm": {
          "type": "number"
        },
        "hole_d_mm": {
          "type": "number"
        },
        "cad_kernel": {
          "type": "string"
        },
        "metadata_path": {
          "type": "string"
        },
        "artifacts_checked": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "failure_item": {
      "type": "object",
      "required": ["reason_code", "failure_location", "detail"],
      "properties": {
        "reason_code": {
          "type": "string",
          "minLength": 1
        },
        "failure_location": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "revision_feedback_item": {
      "type": "object",
      "required": ["reason_code", "failed_checks", "suggested_revision_action", "traceability_link"],
      "properties": {
        "reason_code": {
          "type": "string",
          "minLength": 1
        },
        "failed_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "suggested_revision_action": {
          "type": "string",
          "minLength": 1
        },
        "traceability_link": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "pass": {
            "const": true
          }
        },
        "required": ["pass"]
      },
      "then": {
        "properties": {
          "failures": {
            "maxItems": 0
          },
          "dimensions_check": {
            "properties": {
              "status": {
                "const": "pass"
              }
            }
          },
          "topology_check": {
            "properties": {
              "status": {
                "const": "pass"
              }
            }
          },
          "unit_consistency": {
            "properties": {
              "status": {
                "const": "pass"
              }
            }
          },
          "manufacturing_profile_rules": {
            "properties": {
              "status": {
                "const": "pass"
              }
            }
          },
          "artifact_provenance_check": {
            "properties": {
              "status": {
                "const": "pass"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "pass": {
            "const": false
          }
        },
        "required": ["pass"]
      },
      "then": {
        "properties": {
          "failures": {
            "minItems": 1
          }
        },
        "anyOf": [
          {
            "required": ["dimensions_check"],
            "properties": {
              "dimensions_check": {
                "properties": {
                  "status": {
                    "const": "fail"
                  }
                }
              }
            }
          },
          {
            "required": ["topology_check"],
            "properties": {
              "topology_check": {
                "properties": {
                  "status": {
                    "const": "fail"
                  }
                }
              }
            }
          },
          {
            "required": ["unit_consistency"],
            "properties": {
              "unit_consistency": {
                "properties": {
                  "status": {
                    "const": "fail"
                  }
                }
              }
            }
          },
          {
            "required": ["manufacturing_profile_rules"],
            "properties": {
              "manufacturing_profile_rules": {
                "properties": {
                  "status": {
                    "const": "fail"
                  }
                }
              }
            }
          },
          {
            "required": ["artifact_provenance_check"],
            "properties": {
              "artifact_provenance_check": {
                "properties": {
                  "status": {
                    "const": "fail"
                  }
                }
              }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "failures": {
            "minItems": 1
          }
        },
        "required": ["failures"]
      },
      "then": {
        "anyOf": [
          {
            "required": ["dimensions_check"],
            "properties": {
              "dimensions_check": {
                "properties": {
                  "status": {
                    "const": "fail"
                  }
                }
              }
            }
          },
          {
            "required": ["topology_check"],
            "properties": {
              "topology_check": {
                "properties": {
                  "status": {
                    "const": "fail"
                  }
                }
              }
            }
          },
          {
            "required": ["unit_consistency"],
            "properties": {
              "unit_consistency": {
                "properties": {
                  "status": {
                    "const": "fail"
                  }
                }
              }
            }
          },
          {
            "required": ["manufacturing_profile_rules"],
            "properties": {
              "manufacturing_profile_rules": {
                "properties": {
                  "status": {
                    "const": "fail"
                  }
                }
              }
            }
          },
          {
            "required": ["artifact_provenance_check"],
            "properties": {
              "artifact_provenance_check": {
                "properties": {
                  "status": {
                    "const": "fail"
                  }
                }
              }
            }
          }
        ]
      }
    }
  ],
  "additionalProperties": false
}
