{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cad-agents.local/schemas/phase1/specification.schema.json",
  "title": "Phase 1 Specification JSON",
  "type": "object",
  "required": ["traceability_id", "requirement_id", "parameter_table", "constraints", "material_candidates", "manufacturing_profile", "validation_plan", "unresolved_risks"],
  "properties": {
    "traceability_id": {
      "type": "string",
      "pattern": "^tr_spec_[A-Za-z0-9_]+$"
    },
    "requirement_id": {
      "type": "string",
      "pattern": "^tr_req_[A-Za-z0-9_]+$"
    },
    "parameter_table": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "number"
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "material_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "manufacturing_profile": {
      "type": "string",
      "minLength": 1
    },
    "validation_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "unresolved_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
